# ── EasyPaper 配置文件 ───────────────────────────────────
# 复制此文件为 .env，按需修改。

# 后端监听地址
EASYPAPER_BIND_ADDR=127.0.0.1:8787

# ── LLM 配置 ────────────────────────────────────────────
# OpenAI 兼容的 API Key（如用 DeepSeek 请填入 DeepSeek 的 key）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# API Base URL（默认 OpenAI，可改为 DeepSeek 等兼容服务）
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 模型名称（base_url 含 deepseek 会自动切 deepseek-chat，否则 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# ── 多 LLM Provider（可选；未配置时继续使用上面的 OPENAI_*）─────
# 下面示例把 DeepSeek 作为主 provider，OpenAI 作为 fallback。
# EASYPAPER_LLM_PROVIDERS=deepseek,openai
# EASYPAPER_LLM_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# EASYPAPER_LLM_PROVIDER_DEEPSEEK_MODEL=deepseek-chat
# EASYPAPER_LLM_PROVIDER_DEEPSEEK_API_KEY_ENV=DEEPSEEK_API_KEY
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
#
# EASYPAPER_LLM_PROVIDER_OPENAI_BASE_URL=https://api.openai.com/v1
# EASYPAPER_LLM_PROVIDER_OPENAI_MODEL=gpt-4o-mini
# EASYPAPER_LLM_PROVIDER_OPENAI_API_KEY_ENV=OPENAI_API_KEY
# EASYPAPER_LLM_PROVIDER_OPENAI_RESPONSES_API=true
#
# 按 agent role 指定 provider 顺序；未配置的 role 会走 default route。
# EASYPAPER_LLM_ROUTE_DEFAULT=deepseek,openai
# EASYPAPER_LLM_ROUTE_READER=deepseek,openai
# EASYPAPER_LLM_ROUTE_SPECIALIST=deepseek,openai
# EASYPAPER_LLM_ROUTE_CONCEPT=deepseek,openai
# EASYPAPER_LLM_ROUTE_REPAIR=openai,deepseek
# EASYPAPER_LLM_ROUTE_STUDY=deepseek,openai
# EASYPAPER_LLM_ROUTE_LITERATURE=openai,deepseek
# EASYPAPER_LLM_ROUTE_TRANSLATION=deepseek,openai

# ── 可选 Web 检索增强 ───────────────────────────────────
# Tavily：只填 API Key 时默认使用 https://api.tavily.com/search
# EASYPAPER_WEB_SEARCH_API_KEY=tvly-xxxxxxxxxxxxxxxx
# EASYPAPER_WEB_SEARCH_URL=https://api.tavily.com/search
#
# SearXNG：如果你自建了 SearXNG JSON endpoint，可直接填 URL
# EASYPAPER_WEB_SEARCH_URL=https://search.example.com/search
#
# 每个概念最多注入多少条外部检索结果
# EASYPAPER_WEB_SEARCH_MAX_RESULTS=4

# ── 路径（一般不用改）───────────────────────────────────
# EASYPAPER_DB_PATH=./data/easypaper.db
# EASYPAPER_UPLOAD_DIR=./data/uploads
# STATIC_DIR=./dist

# ── 生产部署安全项（本地开发一般不用改）──────────────────
# 逗号分隔；未配置时沿用本地开发的 permissive CORS。
# EASYPAPER_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── 概念深潜缓存策略 ───────────────────────────────────
# EASYPAPER_CONCEPT_PREWARM_LIMIT=3
# EASYPAPER_CONCEPT_PREWARM_CONCURRENCY=1
# EASYPAPER_CONCEPT_CACHE_TTL_DAYS=7
